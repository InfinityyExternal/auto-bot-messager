-- SERVER HOP MESSENGER (Auto-Executes on every hop)
-- Now using Rayfield UI (better alternative to Orion)

local queue_on_teleport = syn and syn.queue_on_teleport 
    or queue_on_teleport 
    or (fluxus and fluxus.queue_on_teleport) 
    or (getgenv and getgenv().queue_on_teleport) 
    or function(code) warn("[HopMsg] queue_on_teleport not supported") end

-- Load Rayfield (single stable URL)
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Variables (persists via _G across hops)
local MessageText = "Hello! This is an automated server hop message :)"
_G.HopMsgRunning = _G.HopMsgRunning or false

-- [Your functions stay exactly the same: SendMessage, GetRandomServer, ServerHop, RunLoop]
local function SendMessage()
    pcall(function()
        game:GetService("ReplicatedStorage")
            :WaitForChild("DefaultChatSystemChatEvents")
            :WaitForChild("SayMessageRequest")
            :FireServer(MessageText, "All")
    end)
end

local function GetRandomServer()
    local servers = {}
    local success, resp = pcall(function()
        return game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100")
    end)
    if success then
        local data = game:GetService("HttpService"):JSONDecode(resp).data
        for _, v in ipairs(data) do
            if v.playing < v.maxPlayers and v.id ~= game.JobId then
                table.insert(servers, v.id)
            end
        end
    end
    return #servers > 0 and servers[math.random(1, #servers)] or nil
end

local function ServerHop()
    local serverId = GetRandomServer()
    if serverId then
        game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, serverId)
    else
        game:GetService("TeleportService"):Teleport(game.PlaceId)
    end
end

local runningLoop = false
local function RunLoop()
    if runningLoop then return end
    runningLoop = true
    _G.HopMsgRunning = true

    while _G.HopMsgRunning do
        for i = 1, 10 do
            if not _G.HopMsgRunning then break end
            SendMessage()
            task.wait(2)
        end

        if not _G.HopMsgRunning then break end

        -- Queue auto-reload for next server (update URL to your raw file!)
        queue_on_teleport([[_G.HopMsgRunning = true; loadstring(game:HttpGet("https://raw.githubusercontent.com/InfinityyExternal/auto-bot-messager/main/auto-bot.lua"))()]])

        ServerHop()
        task.wait(0.5)
    end

    runningLoop = false
end

-- Rayfield UI (cleaner & more modern)
local Window = Rayfield:CreateWindow({
    Name = "Server Hop Messenger",
    LoadingTitle = "Server Hop Messenger",
    LoadingSubtitle = "by [your name]",
    ConfigurationSaving = {
        Enabled = false,  -- no need for config save here
        FolderName = nil,
        FileName = "HopMsgConfig"
    },
    Discord = {  -- optional: auto-join your Discord if you have one
        Enabled = false,
        Invite = "",
        RememberJoins = true
    },
    KeySystem = false  -- no key needed
})

local Tab = Window:CreateTab("Main", 4483345998)  -- icon ID or 0 for none

-- Textbox for message
local MessageInput = Tab:CreateInput({
    Name = "Message Text",
    PlaceholderText = "Enter your message here...",
    RemoveTextAfterFocusLost = false,
    Callback = function(Text)
        MessageText = Text
    end
})

-- Start button
Tab:CreateButton({
    Name = "▶ Start (10 msgs → hop → repeat)",
    Callback = function()
        RunLoop()
        Rayfield:Notify({
            Title = "Started",
            Content = "Sending 10 messages then hopping forever...",
            Duration = 5,
            Image = 4483345998  -- optional icon
        })
    end
})

-- Stop button
Tab:CreateButton({
    Name = "⏹ Stop",
    Callback = function()
        _G.HopMsgRunning = false
        Rayfield:Notify({
            Title = "Stopped",
            Content = "Will stop after current batch.",
            Duration = 5
        })
    end
})

-- Auto-start from previous hop
if _G.HopMsgRunning then
    task.spawn(RunLoop)
end

Rayfield:Notify({
    Title = "Loaded",
    Content = "Ready! Enter message and click Start.",
    Duration = 4
})
